<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>DELIGHT | Web Developer</title>
<meta name="description" content="Portfolio of Your Name – Frontend developer building fast, accessible websites.">
<style>
  :root{
    --bg:#0d1117; --card:#161b22; --text:#e6edf3; --muted:#8d96a0;
    --accent:#58a6ff; --accent-2:#3fb950; --radius:16px;
  }
  *{box-sizing:border-box; margin:0; padding:0}
  html{scroll-behavior:smooth}
  body{
    font-family:system-ui,-apple-system,Segoe UI,Roboto,Helvetica,Arial,sans-serif;
    background:var(--bg); color:var(--text); line-height:1.6;
  }
  a{color:var(--accent); text-decoration:none}
  a:hover{text-decoration:underline}
  .wrap{max-width:900px; margin:auto; padding:0 20px}
  
  /* Header */
  header{
    position:sticky; top:0; background:rgba(13,17,23,.8); 
    backdrop-filter:blur(10px); border-bottom:1px solid #21262d;
    padding:16px 0; z-index:10;
  }
  nav{display:flex; justify-content:space-between; align-items:center}
  nav a{margin-left:20px; font-weight:600}
  
  /* Hero */
  .hero{
    display:grid; grid-template-columns:1.2fr .8fr; gap:40px; 
    align-items:center; padding:80px 0;
  }
  .hero h1{font-size:clamp(2rem,5vw,3.5rem); line-height:1.1}
  .hero p{color:var(--muted); margin:16px 0 24px}
  .btn{
    display:inline-block; padding:12px 24px; border-radius:999px;
    background:var(--accent); color:#fff; font-weight:600;
    transition:transform .15s ease;
  }
  .btn:hover{transform:translateY(-2px); text-decoration:none}
  .avatar{
    aspect-ratio:1/1; border-radius:50%;
    background:linear-gradient(135deg,var(--accent),var(--accent-2));
    padding:4px;
  }
  .avatar img{width:100%; height:100%; border-radius:50%; object-fit:cover}
  
  /* Sections */
  section{padding:60px 0; border-bottom:1px solid #21262d}
  h2{font-size:2rem; margin-bottom:20px}
  .card{
    background:var(--card); padding:24px; border-radius:var(--radius);
    border:1px solid #21262d; transition:transform .2s ease;
  }
  .card:hover{transform:translateY(-4px)}
  .grid{display:grid; grid-template-columns:repeat(auto-fit,minmax(240px,1fr)); gap:20px}
  .tag{display:inline-block; padding:4px 10px; margin:4px;
    border:1px solid #30363d; border-radius:999px; font-size:.85rem; color:var(--muted)}
  
  /* Form */
  input,textarea{
    width:100%; padding:12px; margin:8px 0; border-radius:10px;
    border:1px solid #30363d; background:var(--card); color:var(--text); font:inherit;
  }
  input:focus,textarea:focus{outline:2px solid var(--accent); border-color:transparent}
  
  footer{text-align:center; padding:30px 0; color:var(--muted); font-size:.9rem}
  
  @media(max-width:760px){
    .hero{grid-template-columns:1fr; text-align:center}
  }
</style>
</head>
<body>

<header>
  <div class="wrap">
    <nav>
      <strong>CHUKWUNYERE DELIGHT</strong>
      <div>
        <a href="#about">About</a>
        <a href="#work">Work</a>
        <a href="#contact">Contact</a>
      </div>
    </nav>
  </div>
</header>

<main class="wrap">

  <!-- Hero -->
  <section class="hero" id="home">
    <div>
      <h1>I build fast, clean, accessible websites</h1>
      <p>Hi, I’m Your Name. A frontend developer focused on HTML, CSS, and making the web work for everyone.</p>
      <a href="#contact" class="btn">Hire Me</a>
    </div>
    <div class="avatar">
      <img src="me.jpg" alt="Portrait of Your Name">
    </div>
  </section>

  <!-- About -->
  <section id="about">
    <h2>About Me</h2>
    <div class="card">
      <p>I’m a self-taught developer who loves turning ideas into simple, fast websites. I focus on semantic HTML, responsive design, and performance. When I’m not coding, I’m learning and building small projects.</p>
      <div style="margin-top:16px">
        <span class="tag">HTML5</span>
        <span class="tag">CSS3</span>
        <span class="tag">Responsive</span>
        <span class="tag">Accessibility</span>
        <span class="tag">Git</span>
      </div>
    </div>
  </section>

  <!-- Work -->
  <section id="work">
    <h2>Projects</h2>
    <div class="grid">
      <article class="card">
        <h3>Bible Quiz App</h3>
        <p>Interactive quiz built with pure HTML/CSS. Forms, tables, and accessible design.</p>
      </article>
      <article class="card">
        <h3>Business Landing Page</h3>
        <p>Responsive landing page with pricing table and contact form. No frameworks.</p>
      </article>
    </div>
  </section>

  <!-- Contact -->
  <section id="contact">
    <h2>Let’s Talk</h2>
    <div class="card">
      <form action="#" method="post">
        <label for="name">Name</label>
        <input type="text" id="name" required>
        
        <label for="email">Email</label>
        <input type="email" id="email" required>
        
        <label for="msg">Message</label>
        <textarea id="msg" rows="4" required></textarea>
        
        <button class="btn" type="submit">Send Message</button>
      </form>
      <p style="margin-top:16px">Email: hello@chukwunyeredelight.dev</p>
    </div>
  </section>

</main>

<footer>
  © 2026 CHUKWUNYERE DELIGHT. Built with HTML & CSS only.
</footer>

</body>
</html>
